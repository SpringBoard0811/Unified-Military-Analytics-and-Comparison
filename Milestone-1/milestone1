    "# Function to download the data\n",
    "def download_page(url, filename):\n",
    "    try:\n",
    "        res = requests.get(url, timeout=15)\n",
    "        if res.status_code == 200:\n",
    "            with open(filename, \"w\", encoding=\"utf-8\") as f:\n",
    "                f.write(res.text)\n",
    "        else:\n",
    "            print(f\"Failed: {url}\")\n",
    "    except Exception as e:\n",
    "        print(f\"Error {url} -> {e}\")"
   ]
